# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_here
STRIPE_SECRET_KEY=sk_live_or_test_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_STARTER_MONTHLY_PRICE_ID=price_xxx
STRIPE_STARTER_ANNUAL_PRICE_ID=price_xxx
STRIPE_GROWTH_MONTHLY_PRICE_ID=price_xxx
STRIPE_GROWTH_ANNUAL_PRICE_ID=price_xxx
STRIPE_PARTNER_MONTHLY_PRICE_ID=price_xxx
STRIPE_PARTNER_ANNUAL_PRICE_ID=price_xxx

# QuickBooks Online (optional — for revenue sync)
QBO_CLIENT_ID=your_qbo_client_id
QBO_CLIENT_SECRET=your_qbo_client_secret
QBO_REFRESH_TOKEN=your_qbo_refresh_token
QBO_REALM_ID=your_qbo_realm_id
QBO_CUSTOMER_REF_ID=58
QBO_ITEM_REF_ID=1
QBO_ITEM_REF_NAME=Services

# Cron job protection (set to a random secret, pass as Bearer token in Vercel Cron config)
CRON_SECRET=your_cron_secret_here

# Backend (FastAPI agent engine)
BACKEND_URL=http://localhost:8000
BACKEND_API_KEY=your_backend_api_key_here

# Upstash Redis (for durable rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Site
NEXT_PUBLIC_SITE_URL=https://sanantonioaiagents.com

# Observability (optional)
SENTRY_DSN=https://your-sentry-dsn
