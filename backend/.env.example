# Database (default: SQLite; swap to Postgres URI for production)
DATABASE_URL=sqlite:///./marketplace.db

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
